# ============================================================
# 議事録管理システム 環境変数サンプル
# .env.local にコピーして値を設定してください
# ============================================================

# ------------------------------------------------------------
# Database（Supabase の場合）
# Supabase ダッシュボード → Settings → Database → Connection string
# "Transaction pooler" (port 6543) を使用
# ------------------------------------------------------------
DATABASE_URL="postgresql://postgres.XXXX:PASSWORD@aws-0-ap-northeast-1.pooler.supabase.com:6543/postgres"

# ------------------------------------------------------------
# Storage（Supabase Storage S3互換API の場合）
# Supabase ダッシュボード → Storage → S3 Connection
# ------------------------------------------------------------
STORAGE_ENDPOINT="https://XXXX.supabase.co/storage/v1/s3"
STORAGE_BUCKET_NAME="meeting-archive"
STORAGE_ACCESS_KEY="your-access-key-id"
STORAGE_SECRET_KEY="your-secret-access-key"
STORAGE_REGION="ap-northeast-1"

# ------------------------------------------------------------
# AI API（どちらか一方を設定）
# ------------------------------------------------------------
OPENAI_API_KEY=""
ANTHROPIC_API_KEY=""

# ------------------------------------------------------------
# Worker（文字起こし用社内PC）
# ------------------------------------------------------------
TRANSCRIPTION_WORKER_ENABLED="true"
INTERNAL_API_BASE_URL="https://your-app.vercel.app"

# ------------------------------------------------------------
# Auth（NextAuth）
# openssl rand -hex 32 で生成
# ------------------------------------------------------------
AUTH_SECRET="your-random-secret-here"
NEXTAUTH_URL="https://your-app.vercel.app"
